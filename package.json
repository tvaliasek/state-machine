{
    "name": "@tvaliasek/state-machine",
    "version": "2.0.4",
    "description": "Very basic framework for building state machines.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./*": {
            "import": {
                "types": "./dist/*.d.mts",
                "default": "./dist/*.mjs"
            },
            "require": {
                "types": "./dist/*.d.cts",
                "default": "./dist/*.cjs"
            }
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsdown",
        "package:build": "tsdown",
        "lint": "eslint --config eslint.config.ts --fix --quiet",
        "test": "jest",
        "docs": "typedoc --out docs src"
    },
    "keywords": [
        "typescript",
        "state",
        "machine",
        "generic",
        "framework"
    ],
    "repository": "https://github.com/tvaliasek/state-machine",
    "author": "tvaliasek",
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.9.0",
        "eslint": "^10.0.2",
        "jest": "^30.2.0",
        "jiti": "^2.6.1",
        "ts-jest": "^29.4.6",
        "tsdown": "^0.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    }
}
